{
  "name": "labelhub",
  "productName": "LabelHub",
  "version": "1.0.0",
  "description": "LabelHub — local annotation & training tool for YOLOv8-OBB",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "start": "concurrently \"vite\" \"electron .\"",
    "dev": "vite",
    "electron": "electron .",
    "build:web": "vite build",
    "build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.labelhub.app",
    "productName": "LabelHub",
    "win": {
      "icon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "fabric": "^5.3.0",
    "axios": "^1.6.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "lucide-react": "^0.294.0",
    "react-dropzone": "^14.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "concurrently": "^8.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0"
  }
}
